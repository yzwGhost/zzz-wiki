{
  "name": "@zzz/desktop",
  "private": true,
  "version": "0.1.0",
  "main": "dist/apps/desktop/electron/main/main.js",
  "scripts": {
    "repair-electron": "node scripts/ensure-electron.cjs",
    "dev": "node scripts/ensure-electron.cjs && concurrently -k \"tsc -p tsconfig.json -w\" \"wait-on dist/apps/desktop/electron/main/main.js && electron .\"",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
